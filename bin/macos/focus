#!/bin/bash

CATEGORIES=(
    "continue-last"
    "dotfiles"
    "projects"
    "stop"
    "waste"
    "work"
)

selected=$(printf "%s\n" "${CATEGORIES[@]}" | fzf)

if [[ -z "$selected" ]]; then
    exit 0
fi

if [[ "$selected" == "stop" ]]; then
    timew stop | sketchybar --trigger timew-stop
elif [[ "$selected" == "continue-last" ]]; then
    timew continue | sketchybar --trigger timew-start
else
    timew start "$selected" | sketchybar --trigger timew-start
fi
