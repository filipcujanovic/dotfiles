[user]
	name = Filip Cujanovic
	email = 29860740+filipcujanovic@users.noreply.github.com
[pager]
	diff = delta
	log = delta
	reflog = delta
	show = delta
[include]
  path = ~/projects/dotfiles/.config/shared/delta/themes/themes.gitconfig
[delta]
	;features = catppuccin-mocha
	features = gruvmax-fang
	navigate = true
	line-numbers = true
[interactive]
	diffFilter = delta --color-only
[pull]
	ff = only
[merge]
	conflictstyle = diff3
[mergetool "nvimdiff"]
	layout = LOCAL,BASE,REMOTE
[merge]
	tool = nvimdiff
[init]
	defaultBranch = main
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
